# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# Get a free token at mixpanel.com → create project → Project Settings → Project Token
# Leave blank to disable analytics (the app works fine without it).
VITE_MIXPANEL_TOKEN=

# Backend URL — only needed when deploying frontend separately
# VITE_API_BASE_URL=https://your-backend.render.com
